{
  "name": "@typeahead/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify API: trie serving, distributed redis cache, write-behind batching, trending.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "load": "tsx scripts/loadDataset.ts",
    "bench": "tsx scripts/benchmark.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pg-copy-streams": "^6.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/pg-copy-streams": "^1.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
