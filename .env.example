# Copy to .env. Every value below is also the in-code default, so the app
# runs with an empty .env against the bundled docker-compose stack.

# --- server ---
PORT=8080
HOST=0.0.0.0

# --- postgres (durable store) ---
# 5433 on the host so it never clashes with a native postgres on 5432. If 5433
# is also taken, set PG_HOST_PORT (compose) and PG_PORT (app) to the same free
# port, e.g. 5544.
PG_HOST=localhost
PG_PORT=5433
# PG_HOST_PORT=5433
PG_USER=typeahead
PG_PASSWORD=typeahead
PG_DB=typeahead

# --- distributed cache: N independent redis nodes, NOT redis cluster ---
# routing across them lives in app code (consistent hashing).
CACHE_NODES=localhost:7070,localhost:7071,localhost:7072
CACHE_VNODES=160
# L1: tiny in-process cache in front of redis. absorbs the hottest prefixes
# and shields a single redis node from a hot-key stampede. 0 disables it.
L1_MAX=2000
L1_TTL_MS=1500
# suggestion cache ttl + anti-stampede jitter (fraction of ttl).
TTL_SUGGEST=45
TTL_JITTER=0.2

# --- write-behind batching ---
# flush when the buffer hits BATCH_SIZE_N rows OR every FLUSH_INTERVAL_MS.
BATCH_SIZE_N=2000
FLUSH_INTERVAL_MS=1000
WAL_KEY=wal:searches

# --- ranking ---
TOP_K=10
W_POP=1
W_REC=2
# recent_score halves after this many seconds of inactivity.
DECAY_HALFLIFE_SEC=1800

# --- trending ---
# how often the leaderboard zset is decayed + trimmed.
TREND_DECAY_INTERVAL_MS=30000
